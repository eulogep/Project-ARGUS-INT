# PHYNX Environment Variables
# Copier vers .env et adapter les valeurs

# ─── Secrets ───────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_a_very_long_secret_key_32chars_minimum
ENCRYPTION_KEY=CHANGE_ME_aes256_key_32bytes!!!

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ─── Neo4j ──────────────────────────────────────────────────
NEO4J_PASSWORD=CHANGE_ME_strong_password

# ─── Tor ────────────────────────────────────────────────────
TOR_CONTROL_PASSWORD=CHANGE_ME_tor_password

# ─── Proxies (optionnel) ─────────────────────────────────────
# Format JSON array :
# PROXY_LIST=[{"url":"socks5://user:pass@host:port","provider":"residential"}]
PROXY_LIST=[]

# ─── APIs externes (optionnel) ───────────────────────────────
# Laisser vide si non disponible (modules fonctionnent sans)
DEHASHED_API_KEY=
INTELX_API_KEY=
CAPTCHA_API_KEY=43284ec24847b2c0012a4df7e2d3c7373

# ─── Ollama Model ───────────────────────────────────────────
OLLAMA_MODEL=llama3

# ─── App ────────────────────────────────────────────────────
APP_ENV=development

# ─── FinOps — Monero (XMR) ──────────────────────────────────
MONERO_RPC_URL=http://monero-wallet-rpc:18082/json_rpc
MONERO_RPC_USER=phynx
MONERO_RPC_PASSWORD=CHANGE_ME_strong_password
# Délai d'attente après tx XMR avant appel API (secondes)
XMR_CONFIRMATION_WAIT_SECONDS=120
MONERO_WALLET_PATH=./data/monero_wallets

# ─── FinOps — Lightning Network (LND) ───────────────────────
LND_REST_URL=https://lnd:8080
# Obtenir le macaroon hex :
#   lncli --macaroonpath=~/.lnd/data/chain/bitcoin/mainnet/invoice.macaroon printmacaroon
LND_MACAROON_HEX=CHANGE_ME_hex_encoded_macaroon
LND_DATA_PATH=./data/lnd

# ─── FinOps — Bitcoin Core ────────────────────────────────────
BITCOIN_RPC_USER=phynx
BITCOIN_RPC_PASSWORD=CHANGE_ME_strong_password

# ─── FinOps — Providers Payants ──────────────────────────────
# Invoices Lightning BOLT11 pré-configurées (renouveler manuellement)
DEHASHED_LN_INVOICE=
PROXY_PROVIDER_API=
PROXY_PROVIDER_LN_INVOICE=
# Adresse XMR du provider IntelX
INTELX_XMR_ADDRESS=

# ─── Crypto Tracing ──────────────────────────────────────────
ETHERSCAN_API_KEY=

# ─── Vector DB — Milvus ──────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ─── IPFS — Local Node ───────────────────────────────────────
IPFS_API_URL=http://ipfs:5001/api/v0

# ─── Phase 5 : Sovereign AI Engine ───────────────────────────

# Moteur d'inférence : "vllm" (production GPU) | "ollama" (dev CPU)
INFERENCE_BACKEND=ollama

# vLLM — Services GPU (production uniquement)
# Les modèles doivent être téléchargés dans /opt/argus-models/ AVANT démarrage
VLLM_HEAVY_URL=http://vllm-heavy:8100/v1
VLLM_HEAVY_MODEL=argus-heavy
VLLM_LIGHT_URL=http://vllm-light:8101/v1
VLLM_LIGHT_MODEL=argus-light
VLLM_VISION_URL=http://vllm-vision:8102/v1
VLLM_VISION_MODEL=argus-vision
# Seuil tokens pour basculer heavy/light
GPU_HEAVY_TOKEN_THRESHOLD=512
LLM_REQUEST_TIMEOUT_S=120

# HuggingFace — Mode air-gapped (modèles en cache local)
HF_HOME=/models/classifiers
HF_HUB_OFFLINE=true
TRANSFORMERS_OFFLINE=true

# AI Firewall — DeBERTa (ProtectAI/deberta-v3-base-prompt-injection)
# Modèle à placer dans /opt/argus-models/classifiers/deberta-prompt-injection/
AI_FIREWALL_ENABLED=true
AI_FIREWALL_MODEL_PATH=/models/classifiers/deberta-prompt-injection
# Score 0-100 au-dessus duquel la requête est bloquée
AI_FIREWALL_THRESHOLD=70

# Milvus — HNSW Tuning Phase 5 (remplace les valeurs par défaut)
MILVUS_HNSW_M=32
MILVUS_HNSW_EF_CONSTRUCTION=400
MILVUS_SEARCH_EF=128
MILVUS_SPARSE_ENABLED=true

# Cognitive Swarm — Agents autonomes
SWARM_MAX_AGENTS=8
# TTL mémoire court terme agent (secondes) — 86400 = 24h
AGENT_MEMORY_TTL_S=86400
# Timeout d'un état de state machine (secondes) — 1800 = 30min
AGENT_STATE_TIMEOUT_S=1800
# Nombre de résultats injectés depuis la mémoire long terme
AGENT_MEMORY_TOP_K=10
