# frontend/.dockerignore
# ============================================================================
# Exclude everything not needed for production build
# ============================================================================

# Version control
.git/
.gitignore

# Node artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js build artifacts (will be rebuilt in container)
.next/
out/

# Development & testing
tests/
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/
playwright-report/

# Documentation
docs/
*.md
LICENSE

# IDE & editor files
.vscode/
.idea/
*.swp
*.swo

# Environment & secrets
.env
.env.*
!.env.example

# Docker (avoid recursive builds)
Dockerfile*
docker-compose*.yml
.dockerignore

# OS files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
