# backend/.env.example

# === Application ===
ENV=development  # production, staging, development
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/argus_int
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
REDIS_URL=redis://localhost:6379/0

# === Security ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_STORAGE=memory://  # Use redis://localhost:6379/1 in production
CSP_REPORT_URI=  # Set to /api/v1/security/csp-report to enable reporting
ENABLE_CORS=false  # Keep false for air-gapped; set true only if frontend on different domain
ALLOWED_ORIGINS=http://localhost:3000  # Comma-separated if CORS enabled

# === Authentication ===
AUTH_MODE=no-auth  # no-auth, jwt, oauth2
JWT_SECRET=  # Required if AUTH_MODE != no-auth
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30

# === WebSocket ===
HEARTBEAT_INTERVAL_SECONDS=30
MAX_CONNECTIONS_PER_INVESTIGATION=10

# === Observability ===
PROMETHEUS_ENABLED=true
METRICS_ENDPOINT=/metrics
OPENTELEMETRY_ENABLED=false  # Enable for distributed tracing

# === OPSEC Warnings ===
# ⚠️ No-Auth mode is for air-gapped deployments only.
# ⚠️ Never expose this backend on a public network without authentication.
# ⚠️ Rotate all secrets before production deployment.
# ⚠️ Review CSP and CORS settings for your specific deployment context.
